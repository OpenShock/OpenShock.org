{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Install Tailwind PostCSS plugin",
			"type": "shell",
			"command": "pnpm",
			"args": [
				"add",
				"-D",
				"@tailwindcss/postcss"
			],
			"isBackground": false,
			"problemMatcher": [],
			"group": "build"
		},
		{
			"label": "Build SvelteKit",
			"type": "shell",
			"command": "pnpm",
			"args": [
				"build"
			],
			"isBackground": false,
			"problemMatcher": [],
			"group": "build"
		},
		{
			"label": "Build SvelteKit",
			"type": "shell",
			"command": "pnpm",
			"args": [
				"build"
			],
			"isBackground": false,
			"group": "build"
		}
	]
}